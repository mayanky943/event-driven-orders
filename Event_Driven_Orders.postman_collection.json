	"item": [
		{
			"name": "Order Operations",
			"item": [
				{
					"name": "Create Successful Order",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"pm.collectionVariables.set(\"last_order_id\", jsonData.id);",
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"customerId\": \"cust-123\",\n    \"lines\": [\n        {\n            \"sku\": \"SKU-A\",\n            \"quantity\": 2,\n            \"unitPrice\": 50.00\n        }\n    ]\n}"
						},
						"url": {
							"raw": "{{order_service_url}}/orders",
							"host": [
								"{{order_service_url}}"
							],
							"path": [
								"orders"
							]
						}
					},
					"response": []
				},
